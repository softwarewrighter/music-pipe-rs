# music-pipe-rs environment setup
# Source this file to get convenient aliases for pipeline stages
#
# Usage:
#   source music-pipe.env
#   seed | motif --notes 16 | humanize | to-midi --out demo.mid
#   seed 12345 | motif --notes 16 | humanize | to-midi --out reproducible.mid
#
# Or add to your shell config:
#   echo 'source /path/to/music-pipe-rs/music-pipe.env' >> ~/.bashrc

# Detect the directory where this script lives
MUSIC_PIPE_DIR="${MUSIC_PIPE_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)}"

# Check for release or debug builds
if [[ -x "${MUSIC_PIPE_DIR}/target/release/motif" ]]; then
    MUSIC_PIPE_BIN="${MUSIC_PIPE_DIR}/target/release"
elif [[ -x "${MUSIC_PIPE_DIR}/target/debug/motif" ]]; then
    MUSIC_PIPE_BIN="${MUSIC_PIPE_DIR}/target/debug"
else
    echo "Warning: music-pipe binaries not found. Run 'cargo build --release' first." >&2
    MUSIC_PIPE_BIN="${MUSIC_PIPE_DIR}/target/release"
fi

# Main entry point (for help/discovery)
alias music-pipe="${MUSIC_PIPE_BIN}/music-pipe"

# Pipeline stage aliases
alias seed="${MUSIC_PIPE_BIN}/seed"
alias motif="${MUSIC_PIPE_BIN}/motif"
alias transpose="${MUSIC_PIPE_BIN}/transpose"
alias humanize="${MUSIC_PIPE_BIN}/humanize"
alias to-midi="${MUSIC_PIPE_BIN}/to-midi"
alias euclid="${MUSIC_PIPE_BIN}/euclid"
alias scale="${MUSIC_PIPE_BIN}/scale"
alias viz="${MUSIC_PIPE_BIN}/viz"

# Convenience function to build all stages
music-pipe-build() {
    (cd "${MUSIC_PIPE_DIR}" && cargo build --release)
}

# Show help for all stages
music-pipe-help() {
    echo "music-pipe-rs - Unix-style MIDI pipeline"
    echo ""
    echo "Start with seed:"
    echo "  seed       - Set random seed (auto if omitted). Always first in pipeline."
    echo ""
    echo "Generators:"
    echo "  motif      - Generate melodic patterns (seed-driven)"
    echo "  euclid     - Generate Euclidean rhythms"
    echo ""
    echo "Transforms:"
    echo "  transpose  - Shift notes by semitones"
    echo "  scale      - Snap notes to a scale (major, minor, dorian, etc.)"
    echo "  humanize   - Add timing/velocity variation (uses pipeline seed)"
    echo "  viz        - Show sparkline visualization (to stderr)"
    echo ""
    echo "Output:"
    echo "  to-midi    - Convert to MIDI file"
    echo ""
    echo "Examples:"
    echo "  seed | motif --notes 16 | humanize | to-midi --out melody.mid"
    echo "  seed 12345 | motif --notes 16 | humanize | to-midi --out reproducible.mid"
    echo "  seed | euclid --steps 16 --pulses 5 | humanize | to-midi --out drums.mid"
    echo ""
    echo "For stage-specific help: <stage> --help"
}

echo "music-pipe-rs loaded. Run 'music-pipe-help' for usage."
